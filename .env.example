# ============================================================
# AI Support Ticket Triage & Routing System
# Environment Variables — copy this to .env and fill in values
# ============================================================

# ------ n8n Core ------
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678

# Change these before any public exposure
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme_strong_password

# Generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=replace_with_32_char_random_string

N8N_DB_NAME=n8n
TIMEZONE=UTC

# ------ PostgreSQL ------
POSTGRES_USER=n8n
POSTGRES_PASSWORD=changeme_db_password
TICKETS_DB_NAME=support_tickets

# ------ Redis ------
REDIS_PASSWORD=changeme_redis_password

# ------ Groq API ------
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ------ pgAdmin (dev only) ------
PGADMIN_EMAIL=admin@triage.local
PGADMIN_PASSWORD=changeme_pgadmin_password

# ------ App Config ------
# Confidence threshold below which tickets go to human review
CONFIDENCE_THRESHOLD=80

# Max AI retry attempts before dead letter queue
MAX_RETRY_ATTEMPTS=3
